{
  "find-suid": {
    "command": "find / -perm -4000 -type f 2>/dev/null",
    "category": "ctf-privesc",
    "description": "Find SUID binaries",
    "aliases": ["suid"]
  },
  "find-caps": {
    "command": "getcap -r / 2>/dev/null",
    "category": "ctf-privesc",
    "description": "Find binaries with Linux capabilities",
    "aliases": ["caps"]
  },
  "find-writable": {
    "command": "find / -writable -type f 2>/dev/null | grep -Ev '/(proc|sys|dev)'",
    "category": "ctf-privesc",
    "description": "Find world-writable files"
  },
  "cron-enum": {
    "command": "echo '=== /etc/crontab ===' && cat /etc/crontab 2>/dev/null && echo '=== cron dirs ===' && ls -la /etc/cron.* 2>/dev/null && echo '=== user crontab ===' && crontab -l 2>/dev/null",
    "category": "ctf-privesc",
    "description": "Enumerate cron jobs",
    "aliases": ["crons"]
  },
  "sudo-check": {
    "command": "sudo -l 2>/dev/null",
    "category": "ctf-privesc",
    "description": "List sudo permissions",
    "aliases": ["sudo-l"]
  },
  "proc-enum": {
    "command": "ps aux --forest",
    "category": "ctf-privesc",
    "description": "List running processes as tree"
  },
  "net-enum": {
    "command": "ss -tulnp 2>/dev/null || netstat -tulnp 2>/dev/null",
    "category": "ctf-privesc",
    "description": "List listening ports and connections",
    "aliases": ["ports"]
  },
  "user-enum": {
    "command": "cat /etc/passwd | grep -v nologin | grep -v false | grep sh$",
    "category": "ctf-privesc",
    "description": "List users with login shells"
  },
  "linpeas-run": {
    "command": "curl -sL https://github.com/peass-ng/PEASS-ng/releases/latest/download/linpeas.sh | bash",
    "category": "ctf-privesc",
    "description": "Run linpeas privilege escalation audit",
    "aliases": ["linpeas"]
  }
}
